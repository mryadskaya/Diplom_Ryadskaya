Процедура ПодставитьПараметрЗапросаSQL(ТекстЗапроса, ИмяПараметра, Значение, Тип = Неопределено, РазрешитьNULL = Ложь)
	Если Тип = Неопределено Тогда
		Тип = Тип("Строка");
	КонецЕсли;
	
	Если РазрешитьNULL И Не ЗначениеЗаполнено(Значение) Тогда
		ЗначениеСтрока = "NULL";
	ИначеЕсли Тип = Тип("Дата") Тогда
		ЗначениеСтрока = "'" + Формат(Значение, "ДФ='yyyy-MM-ddTHH:mm:ss'") + "'";
	ИначеЕсли Тип = Тип("Строка") Тогда
		ЗначениеСтрока = "'" + Значение + "'";
	ИначеЕсли Тип = Тип("Булево") Тогда
		ЗначениеСтрока = Формат(Значение, "БЛ=0; БИ=1");
	ИначеЕсли Тип = Тип("Число") И ТипЗнч(Значение) = Тип("Число") Тогда
		ЗначениеСтрока = Формат(Значение, "ЧН=0; ЧГ=0");
	Иначе
		ЗначениеСтрока = Значение;
	КонецЕсли;
	
	ТекстЗапроса = СтрЗаменить(ТекстЗапроса, "@" + ИмяПараметра, ЗначениеСтрока);
КонецПроцедуры

